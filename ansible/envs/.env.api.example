# ─────────────────────────────────────────────────────────────────────────────
# Benngard Backend — env file for the app server.
# Workflow:
#   make vault-init           # create .env.api.dev.plain and .env.api.prod.plain
#   $EDITOR ansible/envs/.env.api.dev.plain
#   $EDITOR ansible/envs/.env.api.prod.plain
#   make vault-encrypt        # *.plain → encrypted
# Later edits: make vault-decrypt → edit → make vault-encrypt.
#
# Canonical variable docs — backend/.env.example in Benngard_Backend.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED
DATABASE_URL=postgresql://user:pass@neon.tech/db?sslmode=require
SESSION_SECRET=

# RECOMMENDED
OPENROUTER_API_KEY=
RESEND_API_KEY=
ADMIN_EMAILS=andreas@investor-circle.de,ab@swissvalue-group.ch,swissvalue@theinvestmentclub.eu,anton@benngard.de
ADMIN_SECRET=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Public-facing URL — must match the domain in group_vars/<env>_app.yml.
APP_URL=https://benngard.de
APP_BASE_URL=https://benngard.de

# RUNTIME
ENVIRONMENT=production
DEV_MODE=false
AUTO_MIGRATE=true
LOG_LEVEL=INFO

# OBSERVABILITY (OTel collector runs on the app server as part of the infra stack)
OTEL_ENABLED=true
OTEL_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=benngard-backend
APP_VERSION=0.1.0

# OPTIONAL
MIXPANEL_TOKEN=
SLACK_WEBHOOK_URL=
CLOSE_API_KEY=
