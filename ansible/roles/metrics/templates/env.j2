GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD={{ vault_grafana_admin_password }}

# Public URL — Grafana uses it to populate .ExternalURL in alert payloads
# (the "Open in Grafana" link in Telegram). Without it .ExternalURL is
# empty and href becomes a relative path.
GRAFANA_ROOT_URL=https://{{ (nginx_vhosts | first).domain }}

# Private metrics IP — published ports bind only to the private interface
# so nothing is exposed on the public side (Exoscale ens3). See
# docker-compose.yml ports.
METRICS_PRIVATE_IP={{ metrics_private_ip }}
