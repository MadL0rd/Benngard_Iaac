# Rate limiting zones — managed by Ansible, do not edit manually

# Per-IP: 50 req/s covers normal frontend usage (page loads, API calls).
# burst=100 allows short spikes without 429 (e.g. SPA loading a page with 10+ API calls).
limit_req_zone $binary_remote_addr zone=app_api:10m rate=50r/s;

# Return 429 Too Many Requests (standard, client-friendly)
limit_req_status 429;
