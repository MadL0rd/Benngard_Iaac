# {{ item.domain }} — managed by Ansible, do not edit manually
# vhost shape: SPA static + FastAPI backend on same domain.
{% set server_names = ([item.domain] + (item.aliases | default([]))) | join(' ') %}
{% set whitelist = item.whitelist | default(false) %}
{% if cert_exists %}
server {
    listen 80;
    server_name {{ server_names }};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
{% if whitelist %}
{% for ip in nginx_whitelist_ips %}
        allow {{ ip }};
{% endfor %}
        deny all;
{% endif %}
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    server_name {{ server_names }};

    ssl_certificate     /etc/letsencrypt/live/{{ item.domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ item.domain }}/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 1d;

    # Block credential/config scanners and CMS/admin paths.
    location ~* \.(env|git|svn|htpasswd|htaccess|php|asp|aspx|jsp|cgi|sh|sql|bak|backup)$ { return 444; }
    location ~* ^/(wp-|phpmyadmin|xmlrpc|cgi-bin|ecp|owa|autodiscover|webmail|cpanel|plesk|whm|webdav) { return 444; }

    # FastAPI /health — no rate limit (blackbox probes here).
    location = /health {
{% if whitelist %}
{% for ip in nginx_whitelist_ips %}
        allow {{ ip }};
{% endfor %}
        deny all;
{% endif %}
        proxy_pass         http://127.0.0.1:{{ item.upstream_port }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # FastAPI API — rate limited.
    location /api/ {
{% if whitelist %}
{% for ip in nginx_whitelist_ips %}
        allow {{ ip }};
{% endfor %}
        deny all;
{% endif %}
        limit_req zone=app_api burst=100 nodelay;

        proxy_pass         http://127.0.0.1:{{ item.upstream_port }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }

    # Frontend SPA — index.html fallback for client-side routing.
    location / {
{% if whitelist %}
{% for ip in nginx_whitelist_ips %}
        allow {{ ip }};
{% endfor %}
        deny all;
{% endif %}
        root  {{ frontend_static_dir }};
        index index.html;
        try_files $uri $uri/ /index.html;

        # Aggressive cache for versioned assets (hash in filename).
        location ~* \.(js|css|woff2?|ttf|eot|png|jpg|jpeg|gif|ico|svg|webp|avif)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    # nginx stub_status — localhost + docker networks only.
    location = /nginx_status {
        stub_status;
        allow 127.0.0.1;
        allow 172.16.0.0/12;
        deny  all;
    }
}
{% else %}
server {
    listen 80;
    server_name {{ server_names }};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
{% if whitelist %}
{% for ip in nginx_whitelist_ips %}
        allow {{ ip }};
{% endfor %}
        deny all;
{% endif %}
        proxy_pass         http://127.0.0.1:{{ item.upstream_port }};
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
    }
}
{% endif %}
