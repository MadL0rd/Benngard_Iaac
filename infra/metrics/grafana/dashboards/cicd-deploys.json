    {
      "id": 5,
      "type": "logs",
      "title": "Deploy events — service=$service env=$env",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 22,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{unit=\"deploy-gate.service\",service=~\"$service\",env=~\"$env\"} | json | line_format \"event={{.event}} {{.msg}} image={{.image}} id={{.id}}\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableInfiniteScrolling": true
      }
    },
    {
      "id": 6,
      "type": "logs",
      "title": "All deploy-gate logs (raw)",
      "description": "Every line emitted by the deploy-gate service — startup/shutdown, TG-callback errors, reaper sweeps, etc. Not filtered by service/env variables. Useful when debugging the orchestrator itself.",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 30
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{unit=\"deploy-gate.service\"} | json | line_format \"[{{.level}}] {{.msg}}{{ if .event }} event={{.event}}{{ end }}{{ if .service }} service={{.service}}{{ end }}{{ if .env }} env={{.env}}{{ end }}{{ if .image }} image={{.image}}{{ end }}{{ if .id }} id={{.id}}{{ end }}{{ if .err }} err={{.err}}{{ end }}\"",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableInfiniteScrolling": true
      }
    },
    {
