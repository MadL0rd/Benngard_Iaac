          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_duration_milliseconds_count{http_target!=\"\", deployment_environment=~\"$env\", service_name=~\"$service\"}[$__rate_interval])) by (deployment_environment)",
          "legendFormat": "benngard — {{deployment_environment}}",
          "refId": "B"
